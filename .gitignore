# MKPE .gitignore
# Hardened for a provenance/cryptography project. Goal: nothing sensitive or
# transient ever enters git history. When in doubt, exclude; explicit allow-list
# is safer than implicit inclusion.

# ---------------------------------------------------------------------------
# Temporary files used to compose multi-line commit messages
.git-commit-msg.tmp
*.commit-msg.tmp

# ---------------------------------------------------------------------------
# Cryptographic material -- NEVER commit
# ---------------------------------------------------------------------------
# Anything that walks like a private key
**/secrets/
**/keys/
**/private/
**/*.key
**/*.pem
**/*.p12
**/*.pfx
**/*.jks
**/*.crt
**/*.cer
**/keypair.json
**/credentials.json
**/private_key*
**/signing_key*
**/id_ed25519
**/id_rsa
**/id_ecdsa

# Sigstore / cosign local material
*.sig
*.pem.pub
cosign.key
cosign.pub

# RFC 3161 timestamp tokens cached locally (regeneratable)
*.tsr
*.tsq

# Environment files -- never commit, ever
.env
.env.*
!.env.example

# Cursor hooks runtime state (preserved from prior .gitignore)
.cursor/hooks/state/

# Mirror / clone directories some workflows leave around
MKPE_clone/

# ---------------------------------------------------------------------------
# Rust build artifacts
# ---------------------------------------------------------------------------
/target/
**/target/
**/*.rs.bk
*.pdb

# Per-crate Cargo.lock files become orphaned once the workspace is adopted.
# We intentionally do NOT ignore Cargo.lock at the workspace root -- it gets
# committed for binary applications. Run `cargo clean && cargo build --workspace`
# after switching to the workspace layout, then delete stale per-crate lockfiles
# manually.

# ---------------------------------------------------------------------------
# Build outputs that should be release-time artifacts, not source
# ---------------------------------------------------------------------------
MKPE_MODERN.exe
mkpe_service.exe
mkpe_tray.exe
TEST_NEW_UI.exe
MKPE_v*_FROZEN.zip
MKPE_v*_INTEGRATION.zip
*.dll
*.so
*.dylib

# ---------------------------------------------------------------------------
# Generated provenance / vault artifacts (re-derivable from source + keys)
# ---------------------------------------------------------------------------
# .mkpe and .dcx test fixtures live in tests/ and examples/; production
# bundles live under backups/ and are regenerated by the engine.
/backups/
/logs/
**/*.log

# Self-attested build receipts -- replaced by SLSA in-toto provenance in CI
build_attestation.json
canonical_hash.mkpe
canonical_hash.txt

# ---------------------------------------------------------------------------
# IDE / OS / tool noise
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

.cursor/
.qodo/

# ---------------------------------------------------------------------------
# Package manager caches (just in case anyone adds Node/Python tooling later)
# ---------------------------------------------------------------------------
node_modules/
__pycache__/
*.pyc
.venv/
venv/
/build/

# ---------------------------------------------------------------------------
# SBOM and provenance output directory (built in CI; committed copies make
# review noisy and are easily falsifiable when stored in-tree)
# ---------------------------------------------------------------------------
/dist/
/sbom/
*.cdx.json
*.intoto.jsonl
